// Stocknify — Prisma Schema
// Multi-tenant, shared database with Row-Level Security (RLS).
//
// RLS setup (run once after initial migration):
//   ALTER TABLE users ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE products ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE locations ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE stock_levels ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE stock_history ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE integrations ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE rules ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE rule_actions ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE notification_channels ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE alerts ENABLE ROW LEVEL SECURITY;
//   ALTER TABLE notification_deliveries ENABLE ROW LEVEL SECURITY;
//
// For each of the above, add an isolation policy:
//   CREATE POLICY tenant_isolation ON <table>
//     USING (tenant_id = current_setting('app.current_tenant_id')::uuid);
//
// Prisma uses the DATABASE_URL (pooler) for queries and DIRECT_URL for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Tenants — one row per customer company
// ---------------------------------------------------------------------------
model Tenant {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String    @db.Text
  slug                 String    @unique @db.VarChar(63)
  plan                 String    @default("trial") @db.Text
  planStatus           String    @default("active") @map("plan_status") @db.Text
  stripeCustomerId     String?   @map("stripe_customer_id") @db.Text
  stripeSubscriptionId String?   @map("stripe_subscription_id") @db.Text
  trialEndsAt          DateTime? @map("trial_ends_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  users                 User[]
  products              Product[]
  locations             Location[]
  stockLevels           StockLevel[]
  stockHistory          StockHistory[]
  integrations          Integration[]
  rules                 Rule[]
  ruleActions           RuleAction[]
  notificationChannels  NotificationChannel[]
  alerts                Alert[]
  notificationDeliveries NotificationDelivery[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Users — linked to Supabase Auth via id (UUID from auth.users)
// ---------------------------------------------------------------------------
model User {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String   @db.Text
  fullName  String?  @map("full_name") @db.Text
  role      String   @default("user") @db.Text // admin | user | viewer
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant             Tenant  @relation(fields: [tenantId], references: [id])
  acknowledgedAlerts Alert[] @relation("AcknowledgedBy")

  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Products — SKUs managed by the merchant
// ---------------------------------------------------------------------------
model Product {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  sku         String    @db.Text
  name        String    @db.Text
  description String?   @db.Text
  barcode     String?   @db.Text
  unit        String    @default("piece") @db.Text
  metadata    Json      @default("{}") @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  stockLevels  StockLevel[]
  stockHistory StockHistory[]
  alerts       Alert[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Locations — warehouse or fulfiller sites
// ---------------------------------------------------------------------------
model Location {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  name          String    @db.Text
  type          String    @db.Text // fulfiller | own_warehouse | virtual
  integrationId String?   @map("integration_id") @db.Uuid
  address       Json      @default("{}") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  integration  Integration?  @relation(fields: [integrationId], references: [id])
  stockLevels  StockLevel[]
  stockHistory StockHistory[]
  alerts       Alert[]

  @@index([tenantId])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// StockLevel — current stock quantities (upserted on every sync)
// ---------------------------------------------------------------------------
model StockLevel {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  locationId   String    @map("location_id") @db.Uuid
  stockType    String    @map("stock_type") @db.Text // available | reserved | blocked | in_transit | damaged
  quantity     Decimal   @default(0) @db.Decimal(12, 3)
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz
  source       String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([tenantId, productId, locationId, stockType])
  @@index([tenantId])
  @@map("stock_levels")
}

// ---------------------------------------------------------------------------
// StockHistory — append-only audit log (never updated, never deleted)
// ---------------------------------------------------------------------------
model StockHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  stockType  String   @map("stock_type") @db.Text
  quantity   Decimal  @db.Decimal(12, 3)
  delta      Decimal? @db.Decimal(12, 3)
  reason     String?  @db.Text // sync | manual | webhook | adjustment
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("stock_history")
}

// ---------------------------------------------------------------------------
// Integration — shop / ERP / WMS connectors
// ---------------------------------------------------------------------------
model Integration {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  type                  String    @db.Text // shopify | woocommerce | xentral | hive | byrd | zenfulfillment
  name                  String    @db.Text
  status                String    @default("pending") @db.Text
  credentials           Json      @default("{}") @db.JsonB // AES-256-GCM encrypted value stored here
  config                Json      @default("{}") @db.JsonB
  lastSyncAt            DateTime? @map("last_sync_at") @db.Timestamptz
  lastError             String?   @map("last_error") @db.Text
  syncIntervalMinutes   Int       @default(15) @map("sync_interval_minutes")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  locations Location[]

  @@index([tenantId])
  @@map("integrations")
}

// ---------------------------------------------------------------------------
// Rule — configurable threshold alert
// ---------------------------------------------------------------------------
model Rule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String    @db.Text
  description     String?   @db.Text
  isActive        Boolean   @default(true) @map("is_active")
  productFilter   Json      @default("{}") @map("product_filter") @db.JsonB
  locationFilter  Json      @default("{}") @map("location_filter") @db.JsonB
  stockType       String    @map("stock_type") @db.Text
  operator        String    @db.Text // lt | lte | gt | gte | eq
  threshold       Decimal   @db.Decimal(12, 3)
  cooldownMinutes Int       @default(60) @map("cooldown_minutes")
  lastTriggeredAt DateTime? @map("last_triggered_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  ruleActions RuleAction[]
  alerts      Alert[]

  @@index([tenantId])
  @@map("rules")
}

// ---------------------------------------------------------------------------
// RuleAction — which channel to notify when the rule fires
// ---------------------------------------------------------------------------
model RuleAction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  ruleId          String   @map("rule_id") @db.Uuid
  channelId       String   @map("channel_id") @db.Uuid
  messageTemplate String?  @map("message_template") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  rule    Rule                @relation(fields: [ruleId], references: [id])
  channel NotificationChannel @relation(fields: [channelId], references: [id])

  @@index([tenantId])
  @@index([ruleId])
  @@map("rule_actions")
}

// ---------------------------------------------------------------------------
// NotificationChannel — delivery endpoint configuration
// ---------------------------------------------------------------------------
model NotificationChannel {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.Text
  type      String    @db.Text // email | slack | webhook | sms | in_app
  config    Json      @default("{}") @db.JsonB
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  ruleActions           RuleAction[]
  notificationDeliveries NotificationDelivery[]

  @@index([tenantId])
  @@map("notification_channels")
}

// ---------------------------------------------------------------------------
// Alert — a rule that fired at a specific moment
// ---------------------------------------------------------------------------
model Alert {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  ruleId              String    @map("rule_id") @db.Uuid
  productId           String    @map("product_id") @db.Uuid
  locationId          String    @map("location_id") @db.Uuid
  triggeredQuantity   Decimal?  @map("triggered_quantity") @db.Decimal(12, 3)
  threshold           Decimal?  @db.Decimal(12, 3)
  status              String    @default("sent") @db.Text // sent | acknowledged | resolved
  acknowledgedBy      String?   @map("acknowledged_by") @db.Uuid
  acknowledgedAt      DateTime? @map("acknowledged_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id])
  rule                   Rule                   @relation(fields: [ruleId], references: [id])
  product                Product                @relation(fields: [productId], references: [id])
  location               Location               @relation(fields: [locationId], references: [id])
  acknowledgedByUser     User?                  @relation("AcknowledgedBy", fields: [acknowledgedBy], references: [id])
  notificationDeliveries NotificationDelivery[]

  @@index([tenantId])
  @@index([tenantId, ruleId])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
// NotificationDelivery — one record per channel per alert
// ---------------------------------------------------------------------------
model NotificationDelivery {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  alertId   String    @map("alert_id") @db.Uuid
  channelId String    @map("channel_id") @db.Uuid
  status    String    @default("pending") @db.Text // pending | sent | failed
  error     String?   @db.Text
  sentAt    DateTime? @map("sent_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  alert   Alert               @relation(fields: [alertId], references: [id])
  channel NotificationChannel @relation(fields: [channelId], references: [id])

  @@index([tenantId])
  @@index([alertId])
  @@map("notification_deliveries")
}
