// Stocknify — Prisma Schema v3
// Multi-tenant, shared database with Row-Level Security (RLS).
//
// After the initial Prisma migration, apply these manual SQL files in order
// using the Supabase SQL editor (direct connection, not pooler):
//   1. apps/api/src/db/sql/unique-stock-type-definitions.sql
//   2. apps/api/src/db/sql/unique-stock-levels.sql
//   3. apps/api/src/db/sql/rules-check-constraint.sql
//   4. apps/api/src/db/sql/rls-policies.sql
//   5. apps/api/src/db/sql/rls-policies-v3.sql
//   6. apps/api/src/db/sql/unique-notification-templates.sql
//   7. apps/api/src/db/sql/schedule-check-constraints.sql
//   8. apps/api/src/db/sql/attribute-value-tenant-guard.sql
//   9. apps/api/src/db/sql/rls-policies-v4.sql
//  10. apps/api/src/db/sql/incident-check-constraints.sql
//  11. apps/api/src/db/seed/stock-type-definitions.sql (seed, not migration)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Tenants — one row per customer company
// ---------------------------------------------------------------------------
model Tenant {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String    @db.Text
  slug                 String    @unique @db.VarChar(63)
  plan                 String    @default("trial") @map("plan") @db.Text
  planStatus           String    @default("active") @map("plan_status") @db.Text
  stripeCustomerId     String?   @map("stripe_customer_id") @db.Text
  stripeSubscriptionId String?   @map("stripe_subscription_id") @db.Text
  trialEndsAt          DateTime? @map("trial_ends_at") @db.Timestamptz
  // Bundle business logic deferred to Phase 3 — guarded by this flag
  bundleTracking       Boolean   @default(false) @map("bundle_tracking")
  // Partner / Reseller relationship
  partnerId            String?   @map("partner_id") @db.Uuid
  billingMode          String    @default("direct") @map("billing_mode") @db.Text // 'direct' | 'via_partner'
  discountPercent      Int       @default(0) @map("discount_percent")
  referralCode         String?   @map("referral_code") @db.Text // code used at self-signup
  onboardingSource     String    @default("self_signup") @map("onboarding_source") @db.Text // 'self_signup' | 'partner_invite' | 'referral'
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  users                  User[]
  stockTypeDefinitions   StockTypeDefinition[]
  products               Product[]
  productVariants        ProductVariant[]
  productBundles         ProductBundle[]
  batches                Batch[]
  locations              Location[]
  storageLocations       StorageLocation[]
  stockLevels            StockLevel[]
  stockMovements         StockMovement[]
  integrations           Integration[]
  rules                  Rule[]
  ruleActions            RuleAction[]
  notificationChannels   NotificationChannel[]
  alerts                 Alert[]
  variantLocationConfigs VariantLocationConfig[]
  notificationDeliveries          NotificationDelivery[]
  partner                         Partner?                          @relation(fields: [partnerId], references: [id])
  partnerUsers                    PartnerUser[]
  externalReferences              ExternalReference[]
  integrationCredentials          IntegrationCredential[]
  integrationAttributeDefinitions IntegrationAttributeDefinition[]
  integrationAttributeValues      IntegrationAttributeValue[]
  csvMappingTemplates             CsvMappingTemplate[]
  integrationSchedules            IntegrationSchedule[]
  notificationTemplates           NotificationTemplate[]
  incidents                       Incident[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Users — linked to Supabase Auth via id (UUID matches auth.users)
// ---------------------------------------------------------------------------
model User {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String   @db.Text
  fullName  String?  @map("full_name") @db.Text
  role      String   @default("user") @db.Text // admin | user | viewer
  locale    String   @default("en") @db.VarChar(10)
  // Super-admin flag — only set directly in DB, no API endpoint to self-promote
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  acknowledgedAlerts Alert[]         @relation("AcknowledgedAlerts")
  createdMovements   StockMovement[] @relation("CreatedBy")
  partnerUsers       PartnerUser[]
  acknowledgedIncidents Incident[]   @relation("AcknowledgedIncidents")

  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// StockTypeDefinition — system defaults + tenant-custom stock types
// tenant_id IS NULL for system defaults; stock type is a free-text string
// validated against this table at runtime — not a TypeScript enum.
// ---------------------------------------------------------------------------
model StockTypeDefinition {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // null = system default
  key         String   @db.Text
  label       String   @db.Text
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  color       String?  @db.Text // hex color for UI display
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  // NOTE: The @@unique below does NOT enforce uniqueness for system defaults
  // (tenant_id IS NULL) because PostgreSQL treats NULL as distinct in UNIQUE constraints.
  // Two partial unique indexes handle this correctly — see:
  // apps/api/src/db/sql/unique-stock-type-definitions.sql
  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("stock_type_definitions")
}

// ---------------------------------------------------------------------------
// Product — master data record; SKU lives on ProductVariant
// A simple product always has exactly one auto-created default variant.
// ---------------------------------------------------------------------------
model Product {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  name          String    @db.Text
  description   String?   @db.Text
  category      String?   @db.Text
  unit          String    @default("piece") @db.Text // piece | kg | liter | etc.
  batchTracking Boolean   @default(false) @map("batch_tracking")
  metadata      Json      @default("{}") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  variants ProductVariant[]
  batches  Batch[]

  @@index([tenantId])
  @@map("products")
}

// ---------------------------------------------------------------------------
// ProductVariant — SKU level (size, color, etc.)
// Every product has at least one variant (auto-created for simple products).
// ---------------------------------------------------------------------------
model ProductVariant {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  productId  String    @map("product_id") @db.Uuid
  sku        String    @db.Text
  name       String?   @db.Text // e.g. "Red / XL" — null for single-variant products
  barcode    String?   @db.Text
  attributes Json      @default("{}") @db.JsonB // {color: "red", size: "XL"}
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  bundleVariantOf        ProductBundle[]        @relation("BundleVariant")
  componentOf            ProductBundle[]        @relation("ComponentVariant")
  stockLevels            StockLevel[]
  stockMovements         StockMovement[]
  alerts                 Alert[]
  variantLocationConfigs VariantLocationConfig[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("product_variants")
}

// ---------------------------------------------------------------------------
// ProductBundle — which variants make up a bundle and in what quantity
// Bundle business logic is deferred to Phase 3. Controlled by tenants.bundleTracking flag.
// ---------------------------------------------------------------------------
model ProductBundle {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  bundleVariantId    String   @map("bundle_variant_id") @db.Uuid
  componentVariantId String   @map("component_variant_id") @db.Uuid
  quantity           Decimal  @db.Decimal(12, 3)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  bundleVariant    ProductVariant @relation("BundleVariant", fields: [bundleVariantId], references: [id])
  componentVariant ProductVariant @relation("ComponentVariant", fields: [componentVariantId], references: [id])

  @@index([tenantId])
  @@map("product_bundles")
}

// ---------------------------------------------------------------------------
// Batch — lot / MHD tracking record, linked to a product
// ---------------------------------------------------------------------------
model Batch {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  productId        String    @map("product_id") @db.Uuid
  batchNumber      String    @map("batch_number") @db.Text
  expiryDate       DateTime? @map("expiry_date") @db.Date
  manufacturedDate DateTime? @map("manufactured_date") @db.Date
  metadata         Json      @default("{}") @db.JsonB
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]
  alerts         Alert[]

  @@unique([tenantId, productId, batchNumber])
  @@index([tenantId])
  @@map("batches")
}

// ---------------------------------------------------------------------------
// Location — fulfiller / own warehouse / virtual site
// ---------------------------------------------------------------------------
model Location {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  name               String    @db.Text
  type               String    @db.Text // fulfiller | own_warehouse | virtual
  integrationId      String?   @map("integration_id") @db.Uuid
  binTrackingEnabled Boolean   @default(false) @map("bin_tracking_enabled")
  address            Json      @default("{}") @db.JsonB
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  integration            Integration?            @relation(fields: [integrationId], references: [id])
  storageLocations       StorageLocation[]
  stockLevels            StockLevel[]
  stockMovements         StockMovement[]
  alerts                 Alert[]
  variantLocationConfigs VariantLocationConfig[]

  @@index([tenantId])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// StorageLocation — bin / shelf / zone within a Location
// ---------------------------------------------------------------------------
model StorageLocation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  locationId     String    @map("location_id") @db.Uuid
  name           String    @db.Text // e.g. "A-01-03" or "Shelf B"
  type           String    @default("bin") @db.Text // bin | shelf | zone | collection
  trackInventory Boolean   @default(true) @map("track_inventory")
  metadata       Json      @default("{}") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  location       Location        @relation(fields: [locationId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@map("storage_locations")
}

// ---------------------------------------------------------------------------
// StockLevel — current quantity per variant/location/storage/batch/type
// NOTE: Uniqueness is enforced by a custom COALESCE index.
// See apps/api/src/db/sql/unique-stock-levels.sql
// ---------------------------------------------------------------------------
model StockLevel {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  variantId         String    @map("variant_id") @db.Uuid
  locationId        String    @map("location_id") @db.Uuid
  storageLocationId String?   @map("storage_location_id") @db.Uuid
  batchId           String?   @map("batch_id") @db.Uuid
  stockType         String    @map("stock_type") @db.Text // references stock_type_definitions.key
  quantity          Decimal   @default(0) @db.Decimal(12, 3)
  lastSyncedAt      DateTime? @map("last_synced_at") @db.Timestamptz
  source            String?   @db.Text // 'manual' | 'shopify' | 'hive' | etc.
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  variant         ProductVariant   @relation(fields: [variantId], references: [id])
  location        Location         @relation(fields: [locationId], references: [id])
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id])
  batch           Batch?           @relation(fields: [batchId], references: [id])

  @@index([tenantId])
  @@index([tenantId, variantId])
  @@map("stock_levels")
}

// ---------------------------------------------------------------------------
// StockMovement — append-only audit record for every stock change
// Replaces stock_history. No updated_at — records are never mutated.
// ---------------------------------------------------------------------------
model StockMovement {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  variantId         String   @map("variant_id") @db.Uuid
  locationId        String   @map("location_id") @db.Uuid
  storageLocationId String?  @map("storage_location_id") @db.Uuid
  batchId           String?  @map("batch_id") @db.Uuid
  stockType         String   @map("stock_type") @db.Text
  quantityBefore    Decimal  @map("quantity_before") @db.Decimal(12, 3)
  quantityAfter     Decimal  @map("quantity_after") @db.Decimal(12, 3)
  delta             Decimal  @db.Decimal(12, 3)
  movementType      String   @map("movement_type") @db.Text // inbound | outbound | correction | transfer | return | disposal | sync
  reason            String?  @db.Text
  referenceType     String?  @map("reference_type") @db.Text // 'order' | 'shipment' | 'adjustment'
  referenceId       String?  @map("reference_id") @db.Text // external document ID
  source            String?  @db.Text // 'manual' | 'shopify' | 'hive' | 'rule_engine' | etc.
  createdBy         String?  @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  variant         ProductVariant   @relation(fields: [variantId], references: [id])
  location        Location         @relation(fields: [locationId], references: [id])
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id])
  batch           Batch?           @relation(fields: [batchId], references: [id])
  createdByUser   User?            @relation("CreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, variantId])
  @@map("stock_movements")
}

// ---------------------------------------------------------------------------
// Integration — shop / ERP / WMS connector
// ---------------------------------------------------------------------------
model Integration {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  type                String    @db.Text // shopify | woocommerce | xentral | hive | byrd | zenfulfillment
  name                String    @db.Text
  status              String    @default("pending") @db.Text // pending | active | error | paused
  credentials         Json      @default("{}") @db.JsonB // AES-256-GCM encrypted
  config              Json      @default("{}") @db.JsonB
  lastSyncAt          DateTime? @map("last_sync_at") @db.Timestamptz
  lastError           String?   @map("last_error") @db.Text
  syncIntervalMinutes Int       @default(15) @map("sync_interval_minutes")
  // Product matching direction: which system is the source of truth for products
  syncDirection       String    @default("shop_to_fulfiller") @map("sync_direction") @db.Text // 'shop_to_fulfiller' | 'fulfiller_to_shop'
  // Health tracking — updated after every sync job
  healthStatus          String    @default("unknown") @map("health_status") @db.Text
  // 'healthy' | 'degraded' | 'failing' | 'paused' | 'unknown'
  lastSuccessfulSyncAt  DateTime? @map("last_successful_sync_at") @db.Timestamptz
  lastErrorAt           DateTime? @map("last_error_at") @db.Timestamptz
  consecutiveFailures   Int       @default(0) @map("consecutive_failures")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant               Tenant                           @relation(fields: [tenantId], references: [id])
  locations            Location[]
  // Note: named 'storedCredentials' to avoid conflict with the `credentials` JSON field above
  storedCredentials    IntegrationCredential[]
  schedules            IntegrationSchedule[]
  externalReferences   ExternalReference[]
  attributeDefinitions IntegrationAttributeDefinition[]
  incidents            Incident[]

  @@index([tenantId])
  @@map("integrations")
}

// ---------------------------------------------------------------------------
// Rule — configurable alert condition
// NOTE: Condition combination validity is enforced by a check constraint.
// See apps/api/src/db/sql/rules-check-constraint.sql
// ---------------------------------------------------------------------------
model Rule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String    @db.Text
  description     String?   @db.Text
  isActive        Boolean   @default(true) @map("is_active")
  // Filters (null = match all)
  variantFilter   Json      @default("{}") @map("variant_filter") @db.JsonB
  locationFilter  Json      @default("{}") @map("location_filter") @db.JsonB
  batchFilter     Json      @default("{}") @map("batch_filter") @db.JsonB
  // Condition — field requirements depend on conditionType (enforced by check constraint)
  conditionType   String    @map("condition_type") @db.Text // stock_level | days_until_expiry | stock_type_transition
  stockType       String?   @map("stock_type") @db.Text // required for stock_level
  operator        String?   @db.Text // lt | lte | gt | gte | eq — required for stock_level
  threshold       Decimal?  @db.Decimal(12, 3) // required for stock_level
  daysThreshold   Int?      @map("days_threshold") // required for days_until_expiry
  // Escalation
  cooldownMinutes Int       @default(60) @map("cooldown_minutes")
  lastTriggeredAt DateTime? @map("last_triggered_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  ruleActions RuleAction[]
  alerts      Alert[]

  @@index([tenantId])
  @@map("rules")
}

// ---------------------------------------------------------------------------
// RuleAction — what to do when a rule fires
// ---------------------------------------------------------------------------
model RuleAction {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  ruleId                String   @map("rule_id") @db.Uuid
  channelId             String   @map("channel_id") @db.Uuid
  messageTemplate       String?  @map("message_template") @db.Text
  // For stock_type_transition rules: auto-reclassify stock to this type
  transitionToStockType String?  @map("transition_to_stock_type") @db.Text
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  rule                  Rule                   @relation(fields: [ruleId], references: [id])
  channel               NotificationChannel    @relation(fields: [channelId], references: [id])
  notificationTemplates NotificationTemplate[]

  @@index([tenantId])
  @@index([ruleId])
  @@map("rule_actions")
}

// ---------------------------------------------------------------------------
// NotificationChannel — delivery endpoint configuration
// ---------------------------------------------------------------------------
model NotificationChannel {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.Text
  type      String    @db.Text // email | slack | webhook | sms | in_app
  config    Json      @default("{}") @db.JsonB
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id])
  ruleActions            RuleAction[]
  notificationDeliveries NotificationDelivery[]

  @@index([tenantId])
  @@map("notification_channels")
}

// ---------------------------------------------------------------------------
// Alert — a rule that fired at a specific moment
// ---------------------------------------------------------------------------
model Alert {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  ruleId          String    @map("rule_id") @db.Uuid
  variantId       String    @map("variant_id") @db.Uuid
  locationId      String    @map("location_id") @db.Uuid
  batchId         String?   @map("batch_id") @db.Uuid
  triggeredValue  Decimal?  @map("triggered_value") @db.Decimal(12, 3) // quantity or days_until_expiry
  threshold       Decimal?  @db.Decimal(12, 3)
  status          String    @default("sent") @db.Text // sent | acknowledged | resolved
  acknowledgedBy  String?   @map("acknowledged_by") @db.Uuid
  acknowledgedAt  DateTime? @map("acknowledged_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id])
  rule                   Rule                   @relation(fields: [ruleId], references: [id])
  variant                ProductVariant         @relation(fields: [variantId], references: [id])
  location               Location               @relation(fields: [locationId], references: [id])
  batch                  Batch?                 @relation(fields: [batchId], references: [id])
  acknowledgedByUser     User?                  @relation("AcknowledgedAlerts", fields: [acknowledgedBy], references: [id])
  notificationDeliveries NotificationDelivery[]

  @@index([tenantId])
  @@index([tenantId, ruleId])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
// VariantLocationConfig — per-variant-per-location export strategy for batch-agnostic stock
// ---------------------------------------------------------------------------
model VariantLocationConfig {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  variantId             String   @map("variant_id") @db.Uuid
  locationId            String   @map("location_id") @db.Uuid
  // If false, NULL batch_id is valid even when product has batch_tracking = true
  batchRequired         Boolean  @default(false) @map("batch_required")
  // How to handle batch-agnostic stock on export: skip | dummy
  exportStrategy        String   @default("skip") @map("export_strategy") @db.Text
  dummyBatchNumber      String?  @map("dummy_batch_number") @db.Text
  dummyExpiryOffsetDays Int?     @map("dummy_expiry_offset_days")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])
  location Location       @relation(fields: [locationId], references: [id])

  @@unique([tenantId, variantId, locationId])
  @@index([tenantId])
  @@map("variant_location_config")
}

// ---------------------------------------------------------------------------
// NotificationDelivery — one record per channel per alert
// ---------------------------------------------------------------------------
model NotificationDelivery {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  alertId   String    @map("alert_id") @db.Uuid
  channelId String    @map("channel_id") @db.Uuid
  status    String    @default("pending") @db.Text // pending | sent | failed
  error     String?   @db.Text
  sentAt    DateTime? @map("sent_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  alert   Alert               @relation(fields: [alertId], references: [id])
  channel NotificationChannel @relation(fields: [channelId], references: [id])

  @@index([tenantId])
  @@index([alertId])
  @@map("notification_deliveries")
}

// ---------------------------------------------------------------------------
// Incident — structured error records from jobs, API handlers, webhooks, etc.
// Merchants see only their own incidents where is_user_visible = true.
// Super-admin sees all incidents across all tenants.
//
// WRITE TRUST BOUNDARY:
// Incidents are ONLY created by the system via service_role (BYPASSRLS).
// Tenant-scoped connections cannot INSERT incidents — enforced by the
// absence of an INSERT RLS policy (PostgreSQL deny-by-default with RLS).
// READ/UPDATE for tenants: only is_user_visible = true incidents.
// READ for super-admin: via service_role BYPASSRLS connection.
// ---------------------------------------------------------------------------
model Incident {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid

  // Source of the incident
  sourceType    String    @map("source_type") @db.Text
  // 'job' | 'api' | 'webhook' | 'rule_engine' | 'system'
  sourceId      String?   @map("source_id") @db.Text
  // Job ID, route path, webhook integration ID, etc.
  integrationId String?   @map("integration_id") @db.Uuid

  // Classification
  severity      String    @default("error") @map("severity") @db.Text
  // 'info' | 'warning' | 'error' | 'critical'
  code          String    @db.Text
  // machine-readable, e.g. 'SHOPIFY_API_TIMEOUT'

  // Messages — two separate fields for two audiences
  title         String    @db.Text
  // short human-readable summary (always set)
  userMessage   String?   @map("user_message") @db.Text
  // readable description for the merchant (nullable — some incidents are admin-only)
  technicalMessage String? @map("technical_message") @db.Text
  // technical details — only shown to super-admin

  // Visibility
  isUserVisible Boolean   @default(false) @map("is_user_visible")
  // true = shown in merchant dashboard

  // Status
  status        String    @default("open") @map("status") @db.Text
  // 'open' | 'acknowledged' | 'resolved'
  acknowledgedBy String?  @map("acknowledged_by") @db.Uuid
  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz

  // Additional context (job payload snippet, stack trace, etc.)
  context       Json      @default("{}") @db.JsonB

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  integration       Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  acknowledgedByUser User?       @relation("AcknowledgedIncidents", fields: [acknowledgedBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, integrationId])
  @@map("incidents")
}

// ---------------------------------------------------------------------------
// Partner — reseller, affiliate, agency, fulfiller, or any entity that
// brings tenants to Stocknify. Two billing modes can coexist per partner.
// ---------------------------------------------------------------------------
model Partner {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.Text
  slug         String    @unique @db.VarChar(63)
  type         String    @default("other") @db.Text // 'fulfiller' | 'erp' | 'agency' | 'freelancer' | 'merchant' | 'other'
  contactName  String?   @map("contact_name") @db.Text
  contactEmail String    @map("contact_email") @db.Text
  status       String    @default("active") @db.Text // 'active' | 'suspended' | 'churned'
  referralCode String    @unique @map("referral_code") @db.Text // unique code for bottom-up self-signup
  // Default billing behavior (can be overridden per tenant)
  defaultBillingMode         String @default("direct_pays") @map("default_billing_mode") @db.Text // 'partner_pays' | 'direct_pays'
  // Discount defaults — separate rates for each billing mode
  partnerPaysDiscountPercent Int    @default(0) @map("partner_pays_discount_percent")
  directPaysDiscountPercent  Int    @default(0) @map("direct_pays_discount_percent")
  // Default plan for partner customers (never trial or starter)
  defaultPlan String @default("growth") @map("default_plan") @db.Text
  // Stripe entities
  stripeCustomerId          String? @map("stripe_customer_id") @db.Text          // for partner_pays aggregated billing
  stripeCouponIdPartnerPays String? @map("stripe_coupon_id_partner_pays") @db.Text // Stripe coupon when partner bills customers
  stripeCouponIdDirectPays  String? @map("stripe_coupon_id_direct_pays") @db.Text  // Stripe coupon when merchant pays directly (affiliate)
  // Internal notes — never shown to partner
  contractNotes String?  @map("contract_notes") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenants      Tenant[]
  partnerUsers PartnerUser[]

  @@map("partners")
}

// ---------------------------------------------------------------------------
// PartnerUser — who can access the partner dashboard
// ---------------------------------------------------------------------------
model PartnerUser {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerId String   @map("partner_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  role      String   @default("viewer") @db.Text // 'admin' | 'viewer'
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  partner Partner @relation(fields: [partnerId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([partnerId, userId])
  @@index([partnerId])
  @@index([tenantId])
  @@map("partner_users")
}

// ---------------------------------------------------------------------------
// ExternalReference — stores external system IDs for any internal resource.
// Polymorphic: resource_type identifies which model resource_id refers to.
// Two indexes: forward lookup (internal → external) and reverse (external → internal).
// ---------------------------------------------------------------------------
model ExternalReference {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  integrationId String   @map("integration_id") @db.Uuid
  // Polymorphic resource reference
  resourceType  String   @map("resource_type") @db.Text // 'product_variant' | 'location' | 'storage_location' | 'batch'
  resourceId    String   @map("resource_id") @db.Uuid   // our internal ID
  externalId    String   @map("external_id") @db.Text   // ID in the external system
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  integration Integration @relation(fields: [integrationId], references: [id])

  // Forward lookup: our ID → external ID (one external ID per resource per integration)
  @@unique([tenantId, integrationId, resourceType, resourceId], map: "external_references_forward_key")
  // Reverse lookup: external ID → our ID (unique — one internal resource per external ID)
  @@unique([tenantId, integrationId, resourceType, externalId], map: "external_references_reverse_key")
  @@index([tenantId])
  @@map("external_references")
}

// ---------------------------------------------------------------------------
// IntegrationCredential — stores credentials for any integration.
// Multiple credentials per integration are supported (e.g. API key + SFTP).
// All sensitive fields are encrypted AES-256-GCM before storage.
// ---------------------------------------------------------------------------
model IntegrationCredential {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  integrationId  String    @map("integration_id") @db.Uuid
  credentialType String    @map("credential_type") @db.Text // 'api_key' | 'sftp' | 'ftp' | 'oauth' | 'webhook' | 'basic_auth'
  name           String    @db.Text // e.g. "Hive Production API", "Xentral SFTP Export"
  // Credential fields — all AES-256-GCM encrypted at rest
  host           String?   @db.Text // SFTP/FTP host
  port           Int?               // SFTP: 22, FTP: 21
  username       String?   @db.Text
  password       String?   @db.Text
  token          String?   @db.Text // API token / bearer token
  secret         String?   @db.Text // webhook secret / API secret
  remotePath     String?   @map("remote_path") @db.Text // SFTP/FTP directory path
  additionalAttributes Json @default("{}") @map("additional_attributes") @db.JsonB
  isActive       Boolean   @default(true) @map("is_active")
  lastVerifiedAt DateTime? @map("last_verified_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  integration Integration @relation(fields: [integrationId], references: [id])
  schedules   IntegrationSchedule[]

  @@index([tenantId])
  @@index([tenantId, integrationId])
  @@map("integration_credentials")
}

// ---------------------------------------------------------------------------
// IntegrationAttributeDefinition — defines user-visible attributes for a
// specific integration + resource type combination.
// Separate from external_references (which are technical IDs).
// ---------------------------------------------------------------------------
model IntegrationAttributeDefinition {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  integrationId String   @map("integration_id") @db.Uuid
  resourceType  String   @map("resource_type") @db.Text // 'product_variant' | 'location' | 'storage_location'
  key           String   @db.Text // e.g. 'temperature_class', 'customs_tariff_number'
  label         String   @db.Text // display name shown in UI
  dataType      String   @map("data_type") @db.Text // 'text' | 'number' | 'boolean' | 'select'
  options       Json?    @db.JsonB // for dataType = 'select': ["chilled", "frozen"]
  isRequired    Boolean  @default(false) @map("is_required")
  validationRegex String? @map("validation_regex") @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  integration Integration @relation(fields: [integrationId], references: [id])
  values      IntegrationAttributeValue[]

  @@unique([tenantId, integrationId, resourceType, key])
  // Composite unique enables composite FK from integration_attribute_values
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("integration_attribute_definitions")
}

// ---------------------------------------------------------------------------
// IntegrationAttributeValue — the actual value for a specific resource
// ---------------------------------------------------------------------------
model IntegrationAttributeValue {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  definitionId String   @map("definition_id") @db.Uuid
  resourceId   String   @map("resource_id") @db.Uuid   // our internal ID
  value        String?  @db.Text // always stored as text; type comes from definition
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant     Tenant                         @relation(fields: [tenantId], references: [id])
  definition IntegrationAttributeDefinition @relation(fields: [definitionId], references: [id])

  // NOTE: Cross-tenant guard enforced in apps/api/src/db/sql/attribute-value-tenant-guard.sql
  // resource_type is derived from definition.resource_type at query time (not duplicated here)
  @@unique([tenantId, definitionId, resourceId])
  @@index([tenantId])
  @@map("integration_attribute_values")
}

// ---------------------------------------------------------------------------
// CsvMappingTemplate — reusable column mapping for CSV import/export.
// column_mappings format: [{csvColumn: "Artikel-Nr", field: "sku", required: true}]
// ---------------------------------------------------------------------------
model CsvMappingTemplate {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  name          String    @db.Text // e.g. "Xentral Stock Export"
  direction     String    @db.Text // 'import' | 'export'
  resourceType  String    @map("resource_type") @db.Text // 'products' | 'stock' | 'locations'
  delimiter     String    @default(",") @db.VarChar(1) // ',' | ';' | tab
  encoding      String    @default("utf-8") @db.Text
  hasHeaderRow  Boolean   @default(true) @map("has_header_row")
  columnMappings Json     @map("column_mappings") @db.JsonB
  defaultValues  Json     @default("{}") @map("default_values") @db.JsonB // static values for unmapped required fields
  sampleData    Json?     @map("sample_data") @db.JsonB // { headers: string[], rows: string[][] } captured during last preview
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  schedules IntegrationSchedule[]

  @@index([tenantId])
  @@map("csv_mapping_templates")
}

// ---------------------------------------------------------------------------
// IntegrationSchedule — automated import/export schedule for any integration.
// Applies to all integration types, not just CSV.
// User-friendly schedule fields are stored alongside the computed cron expression
// so the UI can correctly reconstruct the form when editing.
// ---------------------------------------------------------------------------
// NOTE: CHECK constraints enforced in apps/api/src/db/sql/schedule-check-constraints.sql
// cron_expression must always be derived server-side — never accepted from client input
model IntegrationSchedule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  integrationId String    @map("integration_id") @db.Uuid
  name          String    @db.Text // e.g. "Daily stock import at 06:00"
  resourceType  String    @map("resource_type") @db.Text // 'products' | 'stock' | 'locations' | 'storage_locations'
  direction     String    @db.Text // 'import' | 'export'
  isActive      Boolean   @default(true) @map("is_active")
  // User-friendly schedule configuration (used to rebuild the UI form)
  scheduleType  String    @map("schedule_type") @db.Text // 'interval_minutes' | 'interval_hours' | 'daily' | 'weekly'
  intervalValue Int?      @map("interval_value") // for interval_minutes/hours: e.g. 15 or 4
  timeOfDay     String?   @map("time_of_day") @db.VarChar(5) // for daily/weekly: "06:30" (HH:MM)
  weekdays      Int[]     @map("weekdays") // for weekly: [1,3,5] = Mon,Wed,Fri (ISO: 1=Mon, 7=Sun)
  // Computed cron expression (generated from above fields, never entered by user)
  cronExpression String   @map("cron_expression") @db.Text // e.g. "30 6 * * 1,3,5"
  // Optional: link to CSV mapping template (for CSV integrations)
  csvMappingTemplateId String? @map("csv_mapping_template_id") @db.Uuid
  // Optional: which credentials to use for this schedule
  credentialId  String?   @map("credential_id") @db.Uuid
  // Execution history
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamptz
  lastRunStatus String?   @map("last_run_status") @db.Text // 'success' | 'partial' | 'failed'
  lastRunError  String?   @map("last_run_error") @db.Text
  nextRunAt     DateTime? @map("next_run_at") @db.Timestamptz // computed from cronExpression
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant             Tenant                 @relation(fields: [tenantId], references: [id])
  integration        Integration            @relation(fields: [integrationId], references: [id])
  csvMappingTemplate CsvMappingTemplate?    @relation(fields: [csvMappingTemplateId], references: [id])
  credential         IntegrationCredential? @relation(fields: [credentialId], references: [id])

  @@index([tenantId])
  @@index([tenantId, integrationId])
  @@map("integration_schedules")
}

// ---------------------------------------------------------------------------
// NotificationTemplate — locale-aware message templates for rule actions.
// System defaults (tenantId = null) are seeded at startup for 'en' and 'de'.
// Tenants can override system defaults or create their own templates.
// ---------------------------------------------------------------------------
model NotificationTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid // null = system default
  ruleActionId String?  @map("rule_action_id") @db.Uuid // null = global default for channel+locale
  locale       String   @db.VarChar(10) // 'en' | 'de' | 'fr' | 'it' | 'es'
  channelType  String   @map("channel_type") @db.Text // 'email' | 'slack' | 'webhook' | 'sms' | 'in_app'
  subject      String?  @db.Text // email subject only
  body         String   @db.Text // {{variable}} placeholders
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant     Tenant?     @relation(fields: [tenantId], references: [id])
  ruleAction RuleAction? @relation(fields: [ruleActionId], references: [id])

  // NOTE: Uniqueness enforced by partial indexes — see:
  // apps/api/src/db/sql/unique-notification-templates.sql
  // Cannot use @@unique here because tenantId and ruleActionId are nullable
  // and PostgreSQL treats NULLs as distinct in standard UNIQUE constraints.
  @@index([tenantId])
  @@map("notification_templates")
}
